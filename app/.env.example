# Pipeline · environment template.
# Everything is OPTIONAL — the system runs end-to-end with mocks when keys are absent.
# Copy to .env.local and fill in what you have.

# Anthropic — production-quality drafts/strategy. Without this the system
# uses the deterministic mock in lib/claude/mock.ts (still demoable).
ANTHROPIC_API_KEY=

# Optional model overrides (defaults match models picked for cost/quality)
ANTHROPIC_MODEL_PREMIUM=claude-opus-4-7
ANTHROPIC_MODEL_DRAFT=claude-sonnet-4-6
ANTHROPIC_MODEL_TRIAGE=claude-haiku-4-5-20251001

# Hunter.io — email validation. Mock fallback works for demo.
HUNTER_API_KEY=

# Crunchbase — funding signal. Mock signal stream works for demo.
CRUNCHBASE_API_KEY=

# Google OAuth — Gmail send + Calendar. Mock send works for demo.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe — billing. Mock checkout works for demo.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Database — Postgres (Supabase). Required.
# In Vercel, the Supabase integration injects POSTGRES_URL automatically and the
# app falls back to that if DATABASE_URL is unset, so you can leave this blank
# in production.
#
# For local dev, paste your Supabase pooler URL (Project Settings → Database
# → Connection string → URI, "Transaction" mode). Looks like:
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Cron secret — protects the /api/cron/tick endpoint.
CRON_SECRET=change-me

# Public URL — used in checkout success/cancel URLs.
PUBLIC_URL=http://localhost:3000
